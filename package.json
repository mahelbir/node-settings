{
  "name": "@mahelbir/settings",
  "version": "3.0.0",
  "private": false,
  "description": "Lightweight JSON configuration file loader for Node.js with deep get/set support and auto-refresh capability",
  "keywords": [
    "json config",
    "settings",
    "config file"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahelbir/node-settings.git"
  },
  "license": "MIT",
  "author": "Mahmuthan Elbir",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "node --test",
    "prepublishOnly": "npm run build && npm test",
    "relock": "rm -rf node_modules package-lock.json && NODE_ENV= npm install --include=dev --include=optional"
  },
  "dependencies": {
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "tsdown": "^0.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
