{
  "name": "@mahelbir/settings",
  "private": false,
  "description": "Lightweight JSON configuration file loader for Node.js with deep get/set support and auto-refresh capability",
  "keywords": [
    "json config",
    "settings",
    "config file"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahelbir/node-settings.git"
  },
  "author": "Mahmuthan Elbir",
  "license": "MIT",
  "type": "module",
  "files": [
    "lib/**/*"
  ],
  "exports": {
    ".": {
      "import": "./lib/esm/index.mjs",
      "require": "./lib/cjs/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:esm": "npx cross-env BABEL_ENV=esm babel ./src --out-dir ./lib/esm --out-file-extension .mjs",
    "build:cjs": "npx cross-env BABEL_ENV=cjs babel ./src --out-dir ./lib/cjs --out-file-extension .cjs",
    "build": "npm run build:esm && npm run build:cjs",
    "test": "node --test 'tests/**/*.test.js'",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "lodash": "4.18.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "babel-plugin-replace-import-extension": "^1.1.5",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "cross-env": "^10.1.0"
  },
  "version": "3.0.0"
}
